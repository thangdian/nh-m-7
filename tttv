      email: "vanb@gmail.com",
      phone: "0900000002",
      image: "https://i.pravatar.cc/150?img=2",
    ),
    Member(
      name: "Lê Văn C",
      id: "SV003",
      major: "Công nghệ thông tin",
      email: "vanc@gmail.com",
      phone: "0900000003",
      image: "https://i.pravatar.cc/150?img=3",
    ),
    Member(
      name: "Phạm Văn D",
      id: "SV004",
