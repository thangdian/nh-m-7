import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: InterestCalculator(),
    );
  }
}

class InterestCalculator extends StatefulWidget {
  @override
  _InterestCalculatorState createState() => _InterestCalculatorState();
}

class _InterestCalculatorState extends State<InterestCalculator> {
  final moneyController = TextEditingController();
  final rateController = TextEditingController();

  String result = "";

  void calculate() {
    double money = double.tryParse(moneyController.text) ?? 0;
    double rate = double.tryParse(rateController.text) ?? 0;

    if (money <= 0 || rate <= 0) {
      setState(() {
        result = "⚠️ Vui lòng nhập hợp lệ";
      });
      return;
    }

    double years = 72 / rate;

    setState(() {
      result = "💸 ${years.toStringAsFixed(2)} năm để gấp đôi";
    });
  }

  Widget buildInput(String label, IconData icon,
      TextEditingController controller) {
    return Container(
      margin: EdgeInsets.only(bottom: 18),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(16),
        boxShadow: [
          BoxShadow(
            color: Colors.black12,
            blurRadius: 8,
            offset: Offset(0, 3),
          )
        ],
      ),
      child: TextField(
        controller: controller,
        keyboardType: TextInputType.number,
        decoration: InputDecoration(
          prefixIcon: Icon(icon, color: Colors.indigo),
          hintText: label,
          border: InputBorder.none,
          contentPadding: EdgeInsets.symmetric(vertical: 16),
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      // 🌈 nền gradient nhẹ
      body: Container(
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [Color(0xFFE3F2FD), Color(0xFFEDE7F6)],
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
          ),
        ),
        child: SafeArea(
          child: Column(
            children: [
              SizedBox(height: 20),

              // 🔥 Title đẹp hơn
              Text(
                "💰 Interest Calculator",
                style: TextStyle(
                  fontSize: 22,
                  fontWeight: FontWeight.bold,
                  color: Colors.indigo,
                ),
              ),

              SizedBox(height: 30),

              Expanded(
                child: Container(
                  padding: EdgeInsets.all(20),
                  decoration: BoxDecoration(
                    color: Colors.white.withOpacity(0.9),
                    borderRadius: BorderRadius.vertical(
                      top: Radius.circular(30),
                    ),
                  ),
                  child: Column(
                    children: [
                      buildInput("Nhập số tiền", Icons.attach_money,
                          moneyController),
                      buildInput("Lãi suất (%)", Icons.percent,
                          rateController),

                      SizedBox(height: 20),

                      // 🔘 Button đẹp hơn
                      SizedBox(
                        width: double.infinity,
                        child: ElevatedButton(
                          onPressed: calculate,
                          style: ElevatedButton.styleFrom(
                            padding: EdgeInsets.symmetric(vertical: 16),
                            shape: StadiumBorder(),
                            backgroundColor: Colors.indigo,
                            elevation: 5,
                          ),
                          child: Text(
                            "TÍNH TOÁN",
                            style: TextStyle(
                                fontSize: 16, fontWeight: FontWeight.bold),
                          ),
                        ),
                      ),

                      SizedBox(height: 30),

                      // 🎯 Result box đẹp
                      AnimatedContainer(
                        duration: Duration(milliseconds: 400),
                        padding: EdgeInsets.all(16),
                        width: double.infinity,
                        decoration: BoxDecoration(
                          color: result.isEmpty
                              ? Colors.grey.shade100
                              : Colors.indigo.shade50,
                          borderRadius: BorderRadius.circular(16),
                        ),
                        child: Text(
                          result.isEmpty
                              ? "Kết quả sẽ hiển thị ở đây"
                              : result,
                          textAlign: TextAlign.center,
                          style: TextStyle(fontSize: 16),
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
